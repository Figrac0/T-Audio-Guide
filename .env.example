# Backend integration
# - VITE_API_URL: base URL of the backend API (no trailing slash).
# - VITE_USE_MOCK_API: "true" to use the in-memory mock at src/shared/api/mock,
#   "false" to call the real backend defined by VITE_API_URL.
#
# To run against mock data locally:
#   VITE_USE_MOCK_API=true
#   VITE_API_URL=http://localhost:8080/api   # any value; ignored when mock=true
#
# To run against the production backend:
#   VITE_USE_MOCK_API=false
#   VITE_API_URL=https://tguide.enzolu.ru/api

VITE_API_URL=https://tguide.enzolu.ru/api
VITE_USE_MOCK_API=false
